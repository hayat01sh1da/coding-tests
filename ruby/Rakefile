# frozen_string_literal: true

require 'rake/testtask'
require_relative 'calculator_cli_app/src/application'
require_relative 'fibonacci_sequence/src/application'
require_relative 'fizzbuzz/src/application'
require_relative 'letter_matching_inspection/src/application'
require_relative 'nabeatsu/src/application'

task default: :test

desc 'Run CalculatorCliApp::Application'
Rake::Task.define_task(:run_calculator_cli_app) do
  CalculatorCliApp::Application.run!(ARGV)
end

desc 'Print fibonacci sequence'
Rake::Task.define_task(:print_fibonacci_sequence) do
  puts 'Provide the initial number to start the sequence from'
  init_num = $stdin.gets&.chomp&.strip

  puts 'Provide the number of iterations'
  iter = $stdin.gets&.chomp&.strip

  params = { init_num:, iter: }.reject { |_, value| value&.empty? }.transform_values(&:to_i)
  puts fibonacci(**params).join(', ')
end

desc 'Print fizzbuzz sequence'
Rake::Task.define_task(:print_fizzbuzz_sequence) do
  puts 'Provide the initial number to start the sequence from'
  init_num = $stdin.gets&.chomp&.strip

  puts 'Provide the terminal number of stop the sequence at'
  terminal_num = $stdin.gets&.chomp&.strip

  puts 'Which logic do you want to use? (1: if, 2: if and ternary, 3: ternary)'
  logic_type = $stdin.gets&.chomp&.strip

  params = { init_num:, terminal_num:, logic_type: }
           .reject { |_, value| value&.empty? }
           .transform_values(&:to_i)
  init_num, terminal_num, logic_type = params.values_at(:init_num, :terminal_num, :logic_type)

  result = init_num.upto(terminal_num).map do |num|
    case logic_type
    when 1
      fizzbuzz_in_if(num)
    when 2
      fizzbuzz_in_if_and_ternary(num)
    when 3
      fizzbuzz_in_ternary(num)
    else
      num
    end
  end

  puts result.join(', ')
end

desc 'Print the result of letter matching inspection'
Rake::Task.define_task(:print_letter_matching_inspection) do
  puts 'Provide the source string to compare from'
  source = $stdin.gets&.chomp&.strip

  puts 'Provide the target string to compare with'
  target = $stdin.gets&.chomp&.strip

  params = { source:, target: }.reject { |_, value| value&.empty? }
  puts "Result: #{LetterMatchingInspection::Application.exactly_equal_size_and_included?(**params)}"
end

desc 'Print nabeatsu sequence'
Rake::Task.define_task(:print_nabeatsu_sequence) do
  puts 'Provide the initial number to start the sequence from'
  init_num = $stdin.gets&.chomp&.strip

  puts 'Provide the terminal number of stop the sequence at'
  terminal_num = $stdin.gets&.chomp&.strip

  puts 'Which logic do you want to use? (1: if, 2: ternary)'
  logic_type = $stdin.gets&.chomp&.strip

  params = { init_num:, terminal_num:, logic_type: }
           .reject { |_, value| value&.empty? }
           .transform_values(&:to_i)
  init_num, terminal_num, logic_type = params.values_at(:init_num, :terminal_num, :logic_type)

  result = init_num.upto(terminal_num).map do |num|
    if logic_type == 1
      go_crazy_in_if(num)
    elsif logic_type == 2
      go_crazy_in_ternary(num)
    else
      num
    end
  end

  puts result.join(', ')
end

desc 'Run all tests'
Rake::TestTask.new do |task|
  task.pattern = File.join('.', '**', '*_test.rb')
end
